{
    "manifest_version": 3,
    "name": "Presto for Trello",
    "version": "1.2.0",
    "description": "Customise Trello checklists: remove strikethrough, change completed item colour, add status badges, and hide the comments panel.",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png",
        "144": "icons/icon-144.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png",
            "144": "icons/icon-144.png"
        }
    },
    "permissions": ["storage"],
    "content_scripts": [
        {
            "matches": ["https://trello.com/*"],
            "css": ["content.css"],
            "js": ["content.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["chips.json"],
            "matches": ["https://trello.com/*"]
        }
    ]
}
